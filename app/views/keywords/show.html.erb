<% content_for :title, @keyword.term %>

<div class="space-y-6">
  <%= link_to "← Voltar", root_path, class: "text-sm font-medium text-blue-700 hover:underline" %>

  <header class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold capitalize"><%= @keyword.term %></h1>
        <% if @snapshot&.is_critical? %>
          <p class="mt-2 inline-flex rounded-full bg-rose-600 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">Ponto crítico</p>
        <% end %>
      </div>
      <% if @snapshot %>
        <p class="text-sm text-slate-600"><%= @snapshot.pct_negative %>% neg · <%= @snapshot.article_count %> matérias</p>
      <% end %>
    </div>
  </header>

  <section class="space-y-4">
    <% if @analyses.any? %>
      <% @analyses.each do |analysis| %>
        <article class="rounded-xl border <%= analysis.relevance_score >= 70 ? 'border-amber-400 bg-amber-50' : 'border-slate-200 bg-white' %> p-5 shadow-sm">
          <div class="mb-3 flex flex-wrap gap-2">
            <%= sentiment_badge("Institucional", analysis.sentiment_institutional) %>
            <%= sentiment_badge("Temático", analysis.sentiment_thematic) %>
            <span class="inline-flex rounded-full bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700">Score <%= analysis.relevance_score %></span>
          </div>
          <h2 class="text-lg font-semibold"><%= analysis.article.title %></h2>
          <p class="mt-1 text-sm text-slate-500"><%= analysis.article.source.name %></p>
          <p class="mt-3 text-slate-700"><%= analysis.article.content_snippet %></p>
          <%= link_to "Ler matéria original", analysis.article.url, target: "_blank", rel: "noopener", class: "mt-4 inline-block text-sm font-medium text-blue-700 hover:underline" %>
        </article>
      <% end %>
    <% else %>
      <p class="text-slate-500">Nenhuma matéria encontrada para este tema no ciclo atual.</p>
    <% end %>
  </section>
</div>
