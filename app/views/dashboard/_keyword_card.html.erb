<%= link_to keyword_path(snapshot.keyword), class: "block rounded-xl border p-4 shadow-sm transition hover:shadow-md #{snapshot_status_class(snapshot)}" do %>
  <div class="mb-3 flex items-start justify-between gap-3">
    <h3 class="font-semibold capitalize"><%= snapshot.keyword.term %></h3>
    <% if snapshot.is_critical? %>
      <span class="rounded-full bg-rose-600 px-2 py-1 text-xs font-semibold uppercase tracking-wide text-white">Atenção</span>
    <% end %>
  </div>

  <% if snapshot.article_count.zero? %>
    <p class="text-sm text-slate-500">Sem cobertura neste ciclo</p>
  <% else %>
    <p class="text-sm text-slate-700"><%= snapshot.pct_negative %>% neg · <%= snapshot.article_count %> matérias</p>
    <div class="mt-3 flex gap-2 text-xs">
      <span class="rounded bg-emerald-100 px-2 py-1 text-emerald-800"><%= snapshot.pct_positive %>% pos</span>
      <span class="rounded bg-amber-100 px-2 py-1 text-amber-800"><%= snapshot.pct_neutral %>% neu</span>
      <span class="rounded bg-rose-100 px-2 py-1 text-rose-800"><%= snapshot.pct_negative %>% neg</span>
    </div>
  <% end %>
<% end %>
