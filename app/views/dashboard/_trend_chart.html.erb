<section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="mb-4 text-lg font-semibold">Tendência 7 dias — % negativo</h2>

  <% if trend_data.present? %>
    <%= line_chart trend_data, height: "320px", library: { scales: { y: { max: 100, min: 0 } } } %>
  <% else %>
    <p class="text-slate-500">Sem histórico suficiente para exibir o gráfico.</p>
  <% end %>
</section>
