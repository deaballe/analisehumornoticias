<section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="mb-4 text-lg font-semibold">Leitura rápida — Top 3</h2>

  <% if briefing&.items.present? %>
    <ol class="space-y-4">
      <% briefing.items.each_with_index do |item, index| %>
        <li class="rounded-lg border border-slate-100 bg-slate-50 p-4">
          <div class="mb-2 flex items-center gap-2 text-sm text-slate-500">
            <span class="font-semibold text-slate-700"><%= index + 1 %>.</span>
            <span><%= item["source"] %></span>
            <span>·</span>
            <span>Score <%= item["relevance_score"] %></span>
          </div>
          <p class="mb-2 text-slate-800"><%= item["summary"] %></p>
          <%= link_to item["title"], item["url"], target: "_blank", rel: "noopener", class: "text-sm font-medium text-blue-700 hover:underline" %>
        </li>
      <% end %>
    </ol>
  <% else %>
    <p class="text-slate-500">Nenhum briefing disponível. Execute o pipeline para gerar dados.</p>
  <% end %>
</section>
