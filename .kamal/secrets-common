# Shared secrets for Kamal (safe to commit — values come from ENV or local files).
# With -d production, Kamal reads this file + .kamal/secrets.production (optional).
#
# Export before deploy:
#   export KAMAL_REGISTRY_PASSWORD=ghp_...
#   export POSTGRES_PASSWORD=...
#   export DEEPSEEK_API_KEY=sk_...
#   export SIDEKIQ_WEB_USER=admin
#   export SIDEKIQ_WEB_PASSWORD=$(openssl rand -base64 24)

RAILS_MASTER_KEY=$(cat config/master.key)

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
DEEPSEEK_API_KEY=$DEEPSEEK_API_KEY
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
SIDEKIQ_WEB_USER=$SIDEKIQ_WEB_USER
SIDEKIQ_WEB_PASSWORD=$SIDEKIQ_WEB_PASSWORD

DATABASE_URL=postgresql://analisehumornoticias:$POSTGRES_PASSWORD@analisehumornoticias-db:5432/analisehumornoticias_production
REDIS_URL=redis://analisehumornoticias-redis:6379/0
